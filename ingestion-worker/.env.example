# gRPC Server Configuration
GRPC_HOST=127.0.0.1
GRPC_PORT=50051

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=nexus-documents
PINECONE_REGION=us-east-1

# Embeddings Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
BATCH_SIZE=100

# Storage
TEMP_DIR=/tmp/nexus-ingestion
S3_BUCKET=
S3_REGION=us-east-1

# Logging
LOG_LEVEL=INFO
